# Copy to .env (gitignored). Values below match a default local Postgres.
# DATABASE_URL is used by Prisma CLI (migrations) and may be a superuser locally.
# Tests derive a NON-superuser app-role connection from it automatically —
# RLS does not bind superusers, so the app/tests must never run as one.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/learntorah_dev"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/learntorah_test"
