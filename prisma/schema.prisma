// LearnTorah — tenancy core (SPEC §4: Identity & tenancy).
// F1 scope: Group, User, Membership. Invitation joins in the auth slice (F2),
// where its accept-flow logic lives; reserved-future entities are NOT built.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// SPEC §4/§6 — roles per group, closed set.
enum Role {
  OWNER
  ADMIN
  EDITOR
  MEMBER
  GUEST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

/// The tenant. Parent of the whole content graph; V1 seeds exactly one.
model Group {
  id           String    @id @default(cuid(2))
  slug         String    @unique
  name         String
  description  String?
  settingsJson Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  memberships  Membership[]
  invitations  Invitation[]
  revisions    Revision[]
  activityLogs ActivityLog[]
  eventLogs    EventLog[]
  categories   Category[]
  topics       Topic[]
  tags         Tag[]
  attachments  Attachment[]
  links        InternalLink[]
}

enum TopicStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Taxonomy (SPEC §4). Self-tree; max depth enforced in the app.
model Category {
  id        String    @id @default(cuid(2))
  groupId   String
  name      String
  slug      String
  parentId  String?
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  group    Group      @relation(fields: [groupId], references: [id], onDelete: Restrict)
  // Composite FK: the parent must live in the SAME group. Postgres checks
  // FKs with row security OFF, so plain id-FKs let a tenant point at another
  // tenant's row (verified). Carrying groupId INTO the key makes the wall
  // structural instead of a service-layer manner.
  parent   Category?  @relation("CategoryTree", fields: [parentId, groupId], references: [id, groupId], onDelete: Restrict)
  children Category[] @relation("CategoryTree")
  topics   Topic[]

  // NOTE the live-row unique is a PARTIAL index (WHERE "deletedAt" IS NULL)
  // in migration `content_taxonomy` — Prisma cannot express partial uniques,
  // and declaring the absolute one here would make the next `migrate dev`
  // restore it and re-break ADR 0002's leave-and-return behaviour.
  @@unique([id, groupId])
  @@index([groupId, parentId, position])
}

/// The organizing spine of the whole content graph (SPEC §4).
model Topic {
  id          String      @id @default(cuid(2))
  groupId     String
  title       String
  slug        String
  description String?
  categoryId  String?
  status      TopicStatus @default(DRAFT)
  authorId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  /// DB-GENERATED (migration `search_columns`): weighted tsvector and
  /// normalized text, both computed by Postgres from title+description via
  /// bm_normalize(). Declared as Unsupported so Prisma neither drops them on
  /// the next migrate nor exposes them as writable fields.
  searchVector Unsupported("tsvector")?
  searchText   Unsupported("text")?

  group    Group     @relation(fields: [groupId], references: [id], onDelete: Restrict)
  // Composite FK — the category must be in this group (see Category.parent).
  category Category? @relation(fields: [categoryId, groupId], references: [id, groupId], onDelete: Restrict)
  author   User      @relation("TopicsAuthored", fields: [authorId], references: [id], onDelete: Restrict)
  tags     TopicTag[]

  // NOTE the live-row unique is a PARTIAL index (WHERE "deletedAt" IS NULL)
  // in migration `content_taxonomy` — Prisma cannot express partial uniques,
  // and declaring the absolute one here would make the next `migrate dev`
  // restore it and re-break ADR 0002's leave-and-return behaviour.
  @@unique([id, groupId])
  @@index([groupId, status, updatedAt])
  @@index([groupId, categoryId])
  // Declared so Prisma does not drop them; the columns they cover are
  // DB-generated (see the field comments above).
  @@index([searchVector], type: Gin)
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model Tag {
  id        String    @id @default(cuid(2))
  groupId   String
  name      String
  slug      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  group  Group      @relation(fields: [groupId], references: [id], onDelete: Restrict)
  topics TopicTag[]

  // NOTE both uniques for Tag are PARTIAL indexes (live rows only): slug in
  // `content_taxonomy`, name in `tag_name_unique`. Prisma cannot express
  // partial uniques, so neither is declared here — declaring the absolute
  // form would make the next `migrate dev` restore it.
  @@unique([id, groupId])
}

/// SPEC §4 canonical: per-type join tables with REAL FKs — deliberately not
/// a polymorphic ContentTag (the tag target set is small and stable, so
/// integrity is worth more than uniformity here).
model TopicTag {
  topicId String
  tagId   String
  groupId String

  // Both sides composite: a link row can only join a topic and a tag that
  // both belong to ITS group. Cascade is reserved for the audited purge
  // flow (hard delete is otherwise prohibited, SPEC §7) — link rows are the
  // one thing that should vanish with their parent rather than linger.
  topic Topic @relation(fields: [topicId, groupId], references: [id, groupId], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId, groupId], references: [id, groupId], onDelete: Cascade)

  @@id([topicId, tagId])
  @@index([groupId, tagId])
}

/// SPEC §4: what an Attachment may hang off. Closed set on purpose — the
/// polymorphism rule allows no DB FK on entityId, so the enum is the only
/// thing keeping the target space honest.
enum AttachmentTargetType {
  DISCUSSION
  CONTRIBUTION
  ARTICLE
  NOTE
  NEWSPOST
  TABLEBLOCK
  SUMMARY
}

enum AttachmentKind {
  IMAGE
  PDF
  FILE
}

/// SPEC §4: the directed content graph. Both ends are polymorphic.
enum LinkTargetType {
  TOPIC
  DISCUSSION
  CONTRIBUTION
  SUMMARY
  ARTICLE
  NOTE
  TABLEBLOCK
  NEWSPOST
  SOURCE
}

enum LinkRelation {
  RELATED
  REFERENCES
  RESPONDS_TO
  SUPERSEDES
}

/// Uploaded file metadata (SPEC §4/§7). R2 holds the blob; this row holds the
/// key. Polymorphic: discriminator + id, NO DB FK on entityId (SPEC §4 rule).
/// SPEC §4 says integrity should rest on soft-delete-only parents, a
/// transactional cascade, and an orphan sweep — TODO: none of those three
/// exist yet, nor does the `resolveEntity()` helper. Until they do, a stale
/// entityId is possible and nothing collects abandoned blobs.
model Attachment {
  id           String               @id @default(cuid(2))
  groupId      String
  entityType   AttachmentTargetType
  entityId     String
  kind         AttachmentKind
  // FOREVER-unique on purpose (ADR 0002 asks for this to be explicit): the
  // blob outlives the row's tombstone, so a key must never be reused even
  // after the attachment is soft-deleted.
  objectKey    String               @unique
  fileName     String
  mimeType     String
  sizeBytes    Int
  // TODO(SPEC §7): written by nothing yet — the sharp resize/thumbnail and
  // EXIF-strip pipeline lands with the image slice. Columns exist so that
  // pipeline needs no migration; they stay NULL until then.
  width        Int?
  height       Int?
  thumbnailKey String?
  uploadedById String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?

  group      Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  uploadedBy User  @relation("AttachmentsUploaded", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([groupId, entityType, entityId])
}

/// A directed link between two pieces of content (SPEC §4). Polymorphic on
/// both ends, so no FK either side; uniqueness stops duplicate edges.
model InternalLink {
  id          String         @id @default(cuid(2))
  groupId     String
  fromType    LinkTargetType
  fromId      String
  toType      LinkTargetType
  toId        String
  relation    LinkRelation   @default(RELATED)
  createdById String
  createdAt   DateTime       @default(now())
  deletedAt   DateTime?

  group     Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  createdBy User  @relation("LinksCreated", fields: [createdById], references: [id], onDelete: Restrict)

  // NOTE the live-row edge unique is a PARTIAL index in migration
  // `attachments_links` — Prisma cannot express partial uniques, and it must
  // lead with groupId (unique indexes are enforced BELOW RLS, so a shared
  // key across tenants would collide on rows one tenant cannot even see).
  @@index([groupId, fromType, fromId])
  @@index([groupId, toType, toId])
}

/// SPEC §4 cross-cutting: closed set of revision-bearing entities.
enum RevisionEntityType {
  DISCUSSION
  CONTRIBUTION
  ARTICLE
  NOTE
  SUMMARY
  TABLEBLOCK
  NEWSPOST
}

/// Full-snapshot version history (SPEC §4/§7): one row per explicit save or
/// 3-minute debounce. Polymorphic (no DB FK on entityId — SPEC §4 rule), but
/// groupId IS a real FK: referential integrity must not depend on RLS alone.
/// Snapshot immutability is APP-enforced (the RLS policy must stay FOR ALL —
/// soft-delete is an UPDATE, purge a DELETE). deletedAt is intended: blanket
/// SPEC convention; purge hard-deletes past it. FUTURE WRITER: version is
/// MAX+1 — serialize per entity (row lock) or two saves race one version.
model Revision {
  id         String             @id @default(cuid(2))
  groupId    String
  entityType RevisionEntityType
  entityId   String
  version    Int
  contentJson Json
  title      String?
  editedById String
  changeNote String?
  createdAt  DateTime           @default(now())
  deletedAt  DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@unique([entityType, entityId, version])
  @@index([groupId, entityType, entityId])
}

/// Append-only audit (SPEC §4): who did what. APPEND-ONLY IS DB-ENFORCED —
/// the migration grants only INSERT+SELECT policies; with RLS FORCEd and no
/// UPDATE/DELETE policy, Postgres rejects both outright. entityType/action
/// are strings by design (free-form dotted actions, no FK, no enum churn).
model ActivityLog {
  id           String   @id @default(cuid(2))
  groupId      String
  actorId      String?
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@index([groupId, createdAt])
}

/// Read-side metrics (SPEC §4): searches, opens, revisits — powers the
/// north-star. Same DB-enforced append-only shape as ActivityLog.
model EventLog {
  id           String   @id @default(cuid(2))
  groupId      String
  userId       String?
  event        String
  entityType   String?
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@index([groupId, createdAt])
  @@index([groupId, event])
}

/// Invite-only onboarding (SPEC §4). Token stored HASHED, single-use; the
/// invite URL carries groupId + raw token, so accept runs inside withGroup —
/// RLS applies to this table like any other groupId row (no bypass needed).
/// Uniqueness = "one PENDING invitation per (group, email)": partial unique
/// WHERE "acceptedAt" IS NULL AND "deletedAt" IS NULL, in the migration.
/// NOTE expiry is time-derived (expiresAt), not a stored flag — an EXPIRED
/// but unaccepted invite still holds the pending slot until the re-invite
/// service SUPERSEDES it (soft-delete old, create new; see ADR 0002 + test).
model Invitation {
  id          String    @id @default(cuid(2))
  groupId     String
  email       String
  role        Role
  tokenHash   String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  group     Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  invitedBy User  @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Restrict)

  // History-inclusive admin listing ("all invitations for this group") — the
  // partial unique only indexes PENDING rows, so it cannot serve this.
  @@index([groupId, email])
}

/// Global identity — deliberately NOT group-scoped (SPEC §4).
/// email is non-null (stricter than the Auth.js adapter's nullable email) —
/// correct for invite-only magic-link; revisit only if an OAuth provider
/// without email ever joins.
model User {
  id            String     @id @default(cuid(2))
  email         String     @unique
  name          String?
  hebrewName    String?
  image         String?
  locale        String     @default("he")
  passwordHash  String?
  emailVerified DateTime?
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  memberships     Membership[]
  accounts        Account[]
  sessions        Session[]
  invitationsSent Invitation[]   @relation("InvitationsSent")
  topicsAuthored  Topic[]        @relation("TopicsAuthored")
  attachments     Attachment[]   @relation("AttachmentsUploaded")
  linksCreated    InternalLink[] @relation("LinksCreated")
}

/// Auth.js (NextAuth v5) adapter tables — global identity, like User; NOT
/// group-scoped, NOT RLS-bound (they carry no groupId). Field shapes are the
/// adapter's contract — do not rename.
model Account {
  id                String  @id @default(cuid(2))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// F2 auth slice MUST couple user deactivation/soft-delete to session
/// revocation — Cascade here fires only on HARD delete, so a soft-deleted
/// user's sessions otherwise survive and keep logging in (debt-hawk, F2a).
model Session {
  id           String   @id @default(cuid(2))
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

/// The User×Group×Role hinge — all RBAC hangs on it (SPEC §4).
/// Row-level security is enforced on this table by migration
/// `rls_memberships`; see src/platform/tenancy for the setter seam.
model Membership {
  id        String           @id @default(cuid(2))
  userId    String
  groupId   String
  role      Role
  status    MembershipStatus
  joinedAt  DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)
  group Group @relation(fields: [groupId], references: [id], onDelete: Restrict)

  // Uniqueness = "one ACTIVE membership per user per group" (ADR 0002, owner-
  // approved deviation from SPEC §4's absolute unique): a partial unique index
  // WHERE "deletedAt" IS NULL lives in migration `identity_schema` — Prisma
  // cannot express partial uniques, so it is deliberately NOT declared here.
  // Soft-deleted rows are history and may repeat.
  @@index([userId, groupId])
  @@index([groupId, role])
}
